{% comment %}
  Alphanix Why Choose Us — Premium centered capsule pills that expand into rounded glassmorphism cards.
{% endcomment %}

{%- style -%}
  #why-choose-{{ section.id }} {
    --bg-color: {%- if section.settings.background_color != blank -%}{{ section.settings.background_color }}{%- else -%}var(--color-background){%- endif -%};
    --text-color: {%- if section.settings.text_color != blank -%}{{ section.settings.text_color }}{%- else -%}var(--color-foreground){%- endif -%};
    --accent-color: {%- if section.settings.accent_color != blank -%}{{ section.settings.accent_color }}{%- else -%}var(--color-accent){%- endif -%};
    --accent-rgb: {%- if section.settings.accent_color != blank -%}{{ section.settings.accent_color.red }} {{ section.settings.accent_color.green }} {{ section.settings.accent_color.blue }}{%- else -%}var(--color-accent-rgb){%- endif -%};
    --border-opacity: {{ section.settings.border_opacity | divided_by: 100.0 }};
    --card-bg-opacity: {{ section.settings.card_bg_opacity | divided_by: 100.0 }};
    --pill-radius: {{ section.settings.pill_radius }}px;
    --card-radius: {{ section.settings.card_radius }}px;
    --pill-gap: {{ section.settings.pill_gap }}px;
    --icon-size: {{ section.settings.icon_size }}px;
    --image-aspect-ratio: {{ section.settings.image_aspect_ratio }};
    --image-width-ratio: {{ section.settings.image_width_ratio }}fr;
    --text-width-ratio: {{ 100 | minus: section.settings.image_width_ratio }}fr;
    
    background-color: var(--bg-color);
    color: var(--text-color);
  }

  {%- if section.settings.text_color != blank -%}
    #why-choose-{{ section.id }} .why-choose__pill {
      --text-color-rgb: {{ section.settings.text_color.red }} {{ section.settings.text_color.green }} {{ section.settings.text_color.blue }};
    }
  {%- else -%}
    #why-choose-{{ section.id }} .why-choose__pill {
      --text-color-rgb: var(--color-foreground-rgb);
    }
  {%- endif -%}

  {%- if section.settings.background_color != blank -%}
    #why-choose-{{ section.id }} .why-choose__pill {
      --card-bg-rgb: {{ section.settings.background_color.red }} {{ section.settings.background_color.green }} {{ section.settings.background_color.blue }};
    }
  {%- else -%}
    #why-choose-{{ section.id }} .why-choose__pill {
      --card-bg-rgb: var(--color-background-rgb);
    }
  {%- endif -%}

  /* Handle custom width sizing and centering */
  #why-choose-{{ section.id }} .why-choose__container {
    {%- if section.settings.width == 'custom' -%}
      max-width: {{ section.settings.custom_width }}%;
    {%- elsif section.settings.width == 'half' -%}
      max-width: 50%;
    {%- elsif section.settings.width == 'narrow' -%}
      max-width: 800px;
    {%- elsif section.settings.width == 'medium' -%}
      max-width: 1100px;
    {%- elsif section.settings.width == 'wide' -%}
      max-width: 1400px;
    {%- elsif section.settings.width == 'full' -%}
      max-width: 100%;
    {%- endif -%}
    width: 100%;
    margin-inline: auto;
  }
  
  @media screen and (max-width: 900px) {
    #why-choose-{{ section.id }} .why-choose__container {
      max-width: 100%; /* Spans full width on mobile for better touch experience */
    }
  }
{%- endstyle -%}

{%- liquid
  assign accent_color = section.settings.accent_color | default: settings.color_palette.color1

  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
-%}

<div class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"></div>

<alphanix-why-choose 
  id="why-choose-{{ section.id }}" 
  class="why-choose section section--{{ section.settings.section_width }} spacing-style {% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}" 
  style="{%- render 'spacing-style', settings: section.settings -%}"
  data-testid="why-choose-section"
  data-accordion-mode="{{ section.settings.accordion_mode }}"
>
  <div class="why-choose__container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank or section.settings.description != blank -%}
      <div class="why-choose__header {% if section.settings.center_header %}why-choose__header--center{% endif %}">
        {%- if section.settings.eyebrow != blank -%}
          <div class="why-choose__eyebrow">— {{ section.settings.eyebrow }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="why-choose__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="why-choose__description paragraph why-choose__description--{{ section.settings.description_size }}">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="why-choose__pills">
      {%- for block in section.blocks -%}
        {%- liquid
          assign row_accent = block.settings.block_accent_color | default: accent_color
          assign row_accent_rgb = row_accent.red | append: ' ' | append: row_accent.green | append: ' ' | append: row_accent.blue
          assign icon_color = block.settings.icon_color | default: row_accent
          assign pill_heading_size = block.settings.heading_size | default: 'h5'
          assign content_direction = block.settings.content_direction | default: 'row'
          assign image_width = block.settings.image_width | default: 100
        -%}
        <details 
          class="why-choose__pill" 
          style="--block-accent: {{ row_accent }}; --block-accent-rgb: {{ row_accent_rgb }}; --icon-color: {{ icon_color }}; --stagger-index: {{ forloop.index0 }};"
          {% if block.settings.open_by_default %}open{% endif %}
          {{ block.shopify_attributes }}
        >
          <summary class="why-choose__pill-summary">
            <div class="why-choose__pill-glow"></div>
            <div class="why-choose__pill-title-area">
              <span class="why-choose__pill-icon">
                {%- if block.settings.custom_svg != blank -%}
                  {{ block.settings.custom_svg }}
                {%- elsif block.settings.icon != 'none' -%}
                  {%- case block.settings.icon -%}
                    {%- when 'diamond' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 12L2 9z"/><path d="M11 3 8 9l4 12 4-12-3-6"/><path d="M2 9h20"/></svg>
                    {%- when 'sparkles' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/><path d="m5 3 1 2.5L8.5 6 6 7 5 9.5 4 7 1.5 6 4 5Z"/><path d="m19 17 1 2.5 2.5.5-2.5 1-1 2.5-1-2.5-2.5-1 2.5-1Z"/></svg>
                    {%- when 'leaf' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 9.8a7 7 0 0 1-9 8.2Z"/><path d="M19 2c-2.26 4.33-5.27 7.14-8 10"/></svg>
                    {%- when 'shield' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 9.7a1 1 0 0 1-.68 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 .76-.97l7-2a1 1 0 0 1 .48 0l7 2A1 1 0 0 1 20 6v7z"/></svg>
                    {%- when 'globe' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                    {%- when 'crown' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7z"/><path d="M5 16v3a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-3"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </span>
              <span class="why-choose__pill-heading {{ pill_heading_size }}">{{ block.settings.title }}</span>
            </div>
            
            <div class="why-choose__pill-trigger">
              <span class="why-choose__pill-indicator">
                <svg class="icon icon-caret" width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </summary>
          
          <div class="why-choose__pill-content {% if block.settings.image != blank %}why-choose__pill-content--has-image{% endif %}"
               data-direction="{{ content_direction }}"
               style="--block-image-width: {{ image_width }}%;{% if block.settings.image_aspect_ratio_block != blank and block.settings.image_aspect_ratio_block != 'use_section' %} --image-aspect-ratio: {{ block.settings.image_aspect_ratio_block }};{% endif %}">
            <div class="why-choose__pill-text-column">
              {%- if block.settings.description != blank -%}
                <div class="why-choose__pill-description paragraph">{{ block.settings.description }}</div>
              {%- endif -%}
              
              {%- if block.settings.link_url != blank and block.settings.link_label != blank -%}
                <div class="why-choose__pill-action">
                  <a href="{{ block.settings.link_url }}" class="why-choose__link">
                    <span>{{ block.settings.link_label }}</span>
                    <svg class="why-choose__link-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M1 11L11 1M11 1H1M11 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              {%- endif -%}
            </div>
            
            {%- if block.settings.image != blank -%}
              {%- liquid
                assign pill_image_alt = block.settings.image.alt | default: block.settings.title
              -%}
              <div class="why-choose__pill-image-column">
                <div class="why-choose__pill-image-wrapper">
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'why-choose__pill-image',
                      loading: 'lazy',
                      widths: '400, 600, 800, 1000, 1200',
                      sizes: '(min-width: 750px) 40vw, 90vw',
                      alt: pill_image_alt
                  }}
                </div>
              </div>
            {%- endif -%}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</alphanix-why-choose>

<script type="module">
  import { Component } from '@theme/component';

  if (!customElements.get('alphanix-why-choose')) {
    customElements.define('alphanix-why-choose', class AlphanixWhyChoose extends Component {
      connectedCallback() {
        super.connectedCallback();
        this.accordionMode = this.dataset.accordionMode === 'true';
        this.pills = this.querySelectorAll('.why-choose__pill');
        
        this.pills.forEach(pill => {
          const summary = pill.querySelector('.why-choose__pill-summary');
          const content = pill.querySelector('.why-choose__pill-content');
          let isAnimating = false;

          if (pill.open && content) {
            content.style.maxHeight = 'none';
          }
          
          summary.addEventListener('click', (e) => {
            e.preventDefault();
            if (isAnimating) return;
            
            if (pill.open) {
              this.closePill(pill, content, () => isAnimating = false);
              isAnimating = true;
            } else {
              isAnimating = true;
              if (this.accordionMode) {
                this.pills.forEach(otherPill => {
                  if (otherPill !== pill && otherPill.open) {
                    const otherContent = otherPill.querySelector('.why-choose__pill-content');
                    this.closePill(otherPill, otherContent, null);
                  }
                });
              }
              this.openPill(pill, content, () => isAnimating = false);
            }
          });

          // Mouse move handler for premium radial glow hover
          pill.addEventListener('mousemove', (e) => {
            const rect = pill.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            pill.style.setProperty('--mouse-x', `${x}px`);
            pill.style.setProperty('--mouse-y', `${y}px`);
          });
        });
      }
      
      openPill(pill, content, callback) {
        pill.open = true;
        content.style.maxHeight = '0px';
        void content.offsetWidth; // Force repaint
        content.style.maxHeight = content.scrollHeight + 60 + 'px';
        
        setTimeout(() => {
          if (pill.open) content.style.maxHeight = 'none';
          if (callback) callback();
        }, 450);
      }
      
      closePill(pill, content, callback) {
        content.style.maxHeight = content.scrollHeight + 'px';
        pill.classList.add('is-closing');
        void content.offsetWidth; // Force repaint
        content.style.maxHeight = '0px';
        
        setTimeout(() => {
          pill.open = false;
          pill.classList.remove('is-closing');
          content.style.maxHeight = '';
          if (callback) callback();
        }, 450);
      }
    });
  }
</script>

{% stylesheet %}
  .why-choose {
    display: block;
    position: relative;
    width: 100%;
  }

  .why-choose__container {
    width: 100%;
  }

  .why-choose__header {
    margin-bottom: 3.5rem;
    max-width: 650px;
  }

  .why-choose__header--center {
    margin-inline: auto;
    text-align: center;
  }

  .why-choose__eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: 1.2rem;
    color: var(--accent-color, var(--color-accent));
    font-weight: 600;
  }

  .why-choose__heading {
    margin: 0 0 1.2rem 0;
  }

  .why-choose__description {
    opacity: 0.8;
    line-height: 1.6;
  }
  .why-choose__description--sm { font-size: var(--font-size--sm, 0.875rem); }
  .why-choose__description--md { font-size: var(--font-size--md, 1rem); }
  .why-choose__description--lg { font-size: var(--font-size--lg, 1.125rem); }

  /* Vertical Stack of Pills */
  .why-choose__pills {
    display: flex;
    flex-direction: column;
    gap: var(--pill-gap, 16px);
    width: 100%;
  }

  /* Individual Pill Card */
  .why-choose__pill {
    width: 100%;
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(var(--text-color-rgb) / var(--border-opacity, 0.08));
    background: rgb(var(--card-bg-rgb) / var(--card-bg-opacity, 0.03));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--pill-radius, 100px);
    transition: border-radius 0.4s cubic-bezier(0.25, 1, 0.5, 1),
                background-color 0.4s ease,
                transform 0.4s cubic-bezier(0.25, 1, 0.5, 1),
                border-color 0.4s ease,
                box-shadow 0.4s ease;
    z-index: 1;
    animation: whyChoosePillIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(var(--stagger-index, 0) * 80ms);
  }

  .why-choose__pill::before {
    content: '';
    position: absolute;
    left: 0;
    top: 18%;
    bottom: 18%;
    width: 3px;
    border-radius: 999px;
    background: var(--block-accent, var(--accent-color, var(--color-accent)));
    opacity: 0;
    transform: scaleY(0.4);
    transition: opacity 0.35s ease, transform 0.45s cubic-bezier(0.25, 1, 0.5, 1);
    z-index: 4;
    pointer-events: none;
  }

  .why-choose__pill[open]::before {
    opacity: 1;
    transform: scaleY(1);
    top: 12%;
    bottom: 12%;
  }

  @keyframes whyChoosePillIn {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .why-choose__pill[open] {
    border-radius: var(--card-radius, 24px);
    background-color: rgb(var(--text-color-rgb) / 0.02);
    border-color: rgb(var(--block-accent-rgb) / 0.2);
    box-shadow: 0 12px 36px rgb(var(--block-accent-rgb) / 0.06);
  }

  /* Hover state */
  @media (any-pointer: fine) and (prefers-reduced-motion: no-preference) {
    .why-choose__pill:hover {
      transform: translateY(-2px);
      border-color: rgb(var(--block-accent-rgb) / 0.25);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }
  }

  /* Summary Details Header */
  .why-choose__pill-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.1rem;
    padding-inline: 2rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    position: relative;
    z-index: 3;
    outline: none;
  }

  /* Remove default details marker */
  .why-choose__pill-summary::-webkit-details-marker {
    display: none;
  }

  .why-choose__pill-title-area {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .why-choose__pill-icon {
    color: var(--icon-color, var(--block-accent));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .why-choose__pill-icon svg {
    width: var(--icon-size, 20px);
    height: var(--icon-size, 20px);
    stroke-width: 1.25;
    display: block;
  }

  .why-choose__pill-heading {
    margin: 0;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.3s ease;
  }

  .why-choose__pill-heading.h2 { font-size: var(--font-size--xl, 1.5rem); }
  .why-choose__pill-heading.h3 { font-size: var(--font-size--lg, 1.25rem); }
  .why-choose__pill-heading.h4 { font-size: var(--font-size--md, 1.05rem); }
  .why-choose__pill-heading.h5,
  .why-choose__pill-heading.h6 { font-size: var(--font-size--sm, 0.875rem); }

  .why-choose__pill:hover .why-choose__pill-heading,
  .why-choose__pill[open] .why-choose__pill-heading {
    color: var(--block-accent);
  }

  /* Plus/Minus Indicator */
  .why-choose__pill-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-color);
  }

  .why-choose__pill-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .why-choose__pill[open] .why-choose__pill-indicator {
    transform: rotate(180deg);
  }

  /* Smooth Closing Overrides */
  .why-choose__pill.is-closing {
    border-radius: var(--pill-radius, 100px) !important;
    background-color: rgb(var(--card-bg-rgb) / var(--card-bg-opacity, 0.03)) !important;
    border-color: rgb(var(--text-color-rgb) / var(--border-opacity, 0.08)) !important;
  }
  .why-choose__pill.is-closing .why-choose__pill-content {
    opacity: 0 !important;
    padding-block-start: 0 !important;
    padding-block-end: 0 !important;
  }
  .why-choose__pill.is-closing .why-choose__pill-indicator {
    transform: rotate(0deg) !important;
  }

  .why-choose__pill-indicator svg {
    width: 16px;
    height: 16px;
    stroke-width: 1.25;
    display: block;
    transition: color 0.3s ease;
  }

  .why-choose__pill:hover .why-choose__pill-indicator svg {
    color: var(--block-accent);
  }

  /* Expandable Content Area */
  .why-choose__pill-content {
    position: relative;
    z-index: 2;
    padding-inline: 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    padding-block-start: 0;
    padding-block-end: 0;
    transition: max-height 0.45s cubic-bezier(0.25, 1, 0.5, 1),
                opacity 0.45s cubic-bezier(0.25, 1, 0.5, 1),
                padding-block-start 0.45s cubic-bezier(0.25, 1, 0.5, 1),
                padding-block-end 0.45s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .why-choose__pill[open] .why-choose__pill-content {
    opacity: 1;
    padding-block-start: 0.9rem;
    padding-block-end: 2.0rem;
  }

  .why-choose__pill[open] .why-choose__pill-text-column,
  .why-choose__pill[open] .why-choose__pill-image-column {
    animation: whyChooseContentIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .why-choose__pill[open] .why-choose__pill-image-column {
    animation-delay: 0.08s;
  }

  @keyframes whyChooseContentIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (min-width: 750px) {
    .why-choose__pill[open] .why-choose__pill-content--has-image[data-direction="row"] {
      grid-template-columns: var(--text-width-ratio, 1.2fr) var(--image-width-ratio, 0.8fr);
    }
    
    .why-choose__pill[open] .why-choose__pill-content--has-image[data-direction="row-reverse"] {
      grid-template-columns: var(--image-width-ratio, 0.8fr) var(--text-width-ratio, 1.2fr);
    }
    
    .why-choose__pill[open] .why-choose__pill-content--has-image[data-direction="row-reverse"] .why-choose__pill-text-column {
      order: 2;
    }
    .why-choose__pill[open] .why-choose__pill-content--has-image[data-direction="row-reverse"] .why-choose__pill-image-column {
      order: 1;
    }

    .why-choose__pill[open] .why-choose__pill-content--has-image[data-direction="column"] {
      grid-template-columns: 1fr;
    }
    .why-choose__pill[open] .why-choose__pill-content--has-image[data-direction="column"] .why-choose__pill-image-column {
      width: var(--block-image-width, 100%);
      margin: 0 auto;
    }
  }

  .why-choose__pill-text-column {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    width: 100%;
  }

  .why-choose__pill-description {
    font-size: var(--font-size--sm);
    line-height: 1.7;
    opacity: 0.75;
    margin: 0;
    font-weight: 300;
  }

  .why-choose__pill-action {
    margin-top: 2rem;
    display: flex;
  }

  .why-choose__link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--font-size--xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-color);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .why-choose__link:hover {
    color: var(--block-accent);
  }

  .why-choose__link-arrow {
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .why-choose__link:hover .why-choose__link-arrow {
    transform: translate(3px, -3px);
  }

  /* Image reveal column */
  .why-choose__pill-image-column {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }

  .why-choose__pill-image-wrapper {
    width: 100%;
    aspect-ratio: var(--image-aspect-ratio, 16 / 10);
    border-radius: calc(var(--card-radius, 24px) * 0.65);
    overflow: hidden;
    border: 1px solid rgb(var(--text-color-rgb) / var(--border-opacity, 0.08));
    background: rgb(var(--card-bg-rgb) / var(--card-bg-opacity, 0.03));
  }

  .why-choose__pill-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.06);
    transition: transform 0.85s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .why-choose__pill[open] .why-choose__pill-image {
    transform: scale(1);
  }

  /* Radial hover glow background inside summary */
  .why-choose__pill-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      500px circle at var(--mouse-x, -999px) var(--mouse-y, -999px),
      rgb(var(--block-accent-rgb) / 0.06),
      transparent 80%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .why-choose__pill:hover .why-choose__pill-glow {
    opacity: 1;
  }

  /* Responsive styling */
  @media screen and (max-width: 749px) {
    .why-choose__header {
      margin-bottom: 3rem;
    }
    
    .why-choose__pill-summary {
      padding-block: 1.2rem;
      padding-inline: 1.5rem;
    }
    
    .why-choose__pill-title-area {
      gap: 1rem;
    }
    
    .why-choose__pill-content {
      padding-inline: 1.5rem;
    }
    
    .why-choose__pill[open] .why-choose__pill-content {
      gap: 1.5rem;
      padding-block-end: 2rem;
    }
    
    .why-choose__pill-image-wrapper {
      aspect-ratio: var(--image-aspect-ratio, 16 / 9);
    }

    .why-choose__pill::before {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .why-choose__pill,
    .why-choose__pill[open] .why-choose__pill-text-column,
    .why-choose__pill[open] .why-choose__pill-image-column {
      animation: none;
    }

    .why-choose__pill,
    .why-choose__pill-content,
    .why-choose__pill-image,
    .why-choose__pill-indicator,
    .why-choose__pill::before {
      transition: none;
    }
  }
{% endstylesheet %}

