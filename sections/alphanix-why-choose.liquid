{% comment %}
  Alphanix Proof — Editorial trust strip. Three hard claims, no accordion theater.
{% endcomment %}

{{ 'alphanix-why-choose.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_width = section.settings.section_width | default: 'page-width'
-%}

{%- style -%}
  #why-choose-{{ section.id }} {
    --proof-bg: {% if section.settings.background_color != blank %}{{ section.settings.background_color }}{% else %}#ffffff{% endif %};
    --proof-text: {% if section.settings.text_color != blank %}{{ section.settings.text_color }}{% else %}#000000{% endif %};
    --proof-muted: {% if section.settings.muted_text_color != blank %}{{ section.settings.muted_text_color }}{% else %}#5c5c5c{% endif %};
    --proof-accent: {% if section.settings.accent_color != blank %}{{ section.settings.accent_color }}{% else %}var(--color-accent, #c8102e){% endif %};
    --proof-rule: {% if section.settings.rule_color != blank %}{{ section.settings.rule_color }}{% else %}#e3e3e3{% endif %};
    background-color: var(--proof-bg);
    color: var(--proof-text);
  }
{%- endstyle -%}

<section
  id="why-choose-{{ section.id }}"
  class="alphanix-proof section section--{{ section_width }} spacing-style page-width-normal"
  data-proof-section
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="alphanix-proof__inner">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <header class="alphanix-proof__header" data-proof-reveal>
        {%- if section.settings.heading != blank -%}
          <h2 class="alphanix-proof__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="alphanix-proof__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="alphanix-proof__grid" data-proof-reveal style="--proof-cols: {{ section.blocks.size }}">
        {%- for block in section.blocks -%}
          <article class="alphanix-proof__item" {{ block.shopify_attributes }} style="--stagger: {{ forloop.index0 }}">
            {%- if block.settings.title != blank -%}
              <h3 class="alphanix-proof__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="alphanix-proof__text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('why-choose-{{ section.id }}');
    if (!root) return;

    function reveal() {
      root.classList.add('is-visible');
    }

    function init() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        reveal();
        return;
      }
      if (!('IntersectionObserver' in window)) {
        reveal();
        return;
      }
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            reveal();
            observer.disconnect();
          });
        },
        { threshold: 0.2, rootMargin: '0px 0px -8% 0px' }
      );
      observer.observe(root);
    }

    init();

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        root = document.getElementById('why-choose-{{ section.id }}');
        if (root) init();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Alphanix Proof",
  "tag": "section",
  "class": "alphanix-why-choose-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built different"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "No gimmicks. Just fabric, fit, and finish that hold up."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Body color",
      "default": "#5c5c5c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#c8102e"
    },
    {
      "type": "color",
      "id": "rule_color",
      "label": "Divider color",
      "default": "#e3e3e3"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "claim",
      "name": "Claim",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Heavyweight"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "100% ring-spun cotton. Soft hand. Holds its shape."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Alphanix Proof",
      "blocks": [
        {
          "type": "claim",
          "settings": {
            "title": "Heavyweight",
            "text": "100% ring-spun cotton. Soft hand. Holds its shape."
          }
        },
        {
          "type": "claim",
          "settings": {
            "title": "Athletic fit",
            "text": "True to size. Cut to move — no second-guessing."
          }
        },
        {
          "type": "claim",
          "settings": {
            "title": "Built to last",
            "text": "Ethically sourced. Under 1% returns."
          }
        }
      ]
    }
  ]
}
{% endschema %}
