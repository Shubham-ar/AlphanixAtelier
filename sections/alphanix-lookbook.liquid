{% comment %}
  Alphanix Look Stage — Dark immersive lifestyle panel + supporting reel
{% endcomment %}

{{ 'alphanix-lookbook.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign stage_heading = section.settings.heading
  assign stage_description = section.settings.description
  assign cta_label = section.settings.button_label
  assign cta_link = section.settings.button_link
  assign primary_image = section.settings.image_1
  assign section_width = section.settings.section_width | default: 'page-width'
  assign has_reel = false
  if section.settings.image_2 != blank or section.settings.image_3 != blank
    assign has_reel = true
  endif

  if section_width == 'full-width'
    assign image_sizes = '100vw'
  else
    assign image_sizes = '(min-width: 750px) min(1400px, 100vw), 100vw'
  endif
-%}

{%- style -%}
  #alphanix-lookbook-{{ section.id }} {
    --look-stage-height: {{ section.settings.stage_height }}vh;
    --look-stage-bg: {{ section.settings.background_color }};
    --look-stage-text: {{ section.settings.text_color }};
    --look-stage-muted: {{ section.settings.muted_text_color }};
    --look-stage-cta-bg: {{ section.settings.button_bg_color }};
    --look-stage-cta-text: {{ section.settings.button_text_color }};
    color: var(--look-stage-text);
  }
{%- endstyle -%}

<section
  class="alphanix-lookbook section section--{{ section_width }} spacing-style page-width-normal alphanix-lookbook--{{ section_width }}"
  id="alphanix-lookbook-{{ section.id }}"
  data-look-stage
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="alphanix-lookbook__panel">
    <div class="alphanix-lookbook__stage">
      <div class="alphanix-lookbook__media" data-look-media>
        {%- if primary_image != blank -%}
          {{
            primary_image
            | image_url: width: 3840
            | image_tag:
              class: 'alphanix-lookbook__image',
              loading: 'lazy',
              widths: '750, 1100, 1500, 2000, 2400, 3000, 3840',
              sizes: image_sizes,
              alt: primary_image.alt | default: stage_heading
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'alphanix-lookbook__image placeholder' }}
        {%- endif -%}
        <div class="alphanix-lookbook__scrim" aria-hidden="true"></div>
      </div>

      <div class="alphanix-lookbook__content" data-look-content>
        {%- if stage_heading != blank -%}
          <h2 class="alphanix-lookbook__heading">{{ stage_heading | escape }}</h2>
        {%- endif -%}

        {%- if stage_description != blank -%}
          <p class="alphanix-lookbook__description">{{ stage_description | escape }}</p>
        {%- endif -%}

        {%- if cta_label != blank and cta_link != blank -%}
          <a href="{{ cta_link }}" class="alphanix-lookbook__cta">
            {{ cta_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if has_reel -%}
      <div class="alphanix-lookbook__reel" data-look-reel>
        {%- if section.settings.image_2 != blank -%}
          {%- if cta_link != blank -%}
            <a href="{{ cta_link }}" class="alphanix-lookbook__reel-item">
              {{
                section.settings.image_2
                | image_url: width: 1200
                | image_tag:
                  class: 'alphanix-lookbook__reel-image',
                  loading: 'lazy',
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(min-width: 750px) 40vw, 80vw',
                  alt: section.settings.image_2.alt | default: stage_heading
              }}
            </a>
          {%- else -%}
            <div class="alphanix-lookbook__reel-item">
              {{
                section.settings.image_2
                | image_url: width: 1200
                | image_tag:
                  class: 'alphanix-lookbook__reel-image',
                  loading: 'lazy',
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(min-width: 750px) 40vw, 80vw',
                  alt: section.settings.image_2.alt | default: stage_heading
              }}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.image_3 != blank -%}
          {%- if cta_link != blank -%}
            <a href="{{ cta_link }}" class="alphanix-lookbook__reel-item">
              {{
                section.settings.image_3
                | image_url: width: 1200
                | image_tag:
                  class: 'alphanix-lookbook__reel-image',
                  loading: 'lazy',
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(min-width: 750px) 40vw, 80vw',
                  alt: section.settings.image_3.alt | default: stage_heading
              }}
            </a>
          {%- else -%}
            <div class="alphanix-lookbook__reel-item">
              {{
                section.settings.image_3
                | image_url: width: 1200
                | image_tag:
                  class: 'alphanix-lookbook__reel-image',
                  loading: 'lazy',
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(min-width: 750px) 40vw, 80vw',
                  alt: section.settings.image_3.alt | default: stage_heading
              }}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('alphanix-lookbook-{{ section.id }}');
    if (!root) return;

    function reveal() {
      root.classList.add('is-visible');
    }

    function init() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        reveal();
        return;
      }

      if (!('IntersectionObserver' in window)) {
        reveal();
        return;
      }

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            reveal();
            observer.disconnect();
          });
        },
        { threshold: 0.2, rootMargin: '0px 0px -10% 0px' }
      );

      observer.observe(root);
    }

    init();

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        root = document.getElementById('alphanix-lookbook-{{ section.id }}');
        if (root) init();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Alphanix Look Stage",
  "tag": "section",
  "class": "alphanix-lookbook-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Worn for the long haul"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Heavyweight cotton. Athletic fit. Designed in Toronto."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the look"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Primary image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Reel image 1"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Reel image 2"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "stage_height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Stage height",
      "default": 85
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Description color",
      "default": "#c8c8c8"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#c8102e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Alphanix Look Stage"
    }
  ]
}
{% endschema %}
