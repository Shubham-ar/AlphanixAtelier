{% comment %}
  Alphanix Fit Tiles — Shop by fit: image tiles linking to collections
{% endcomment %}

{{ 'alphanix-fit-tiles.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_width = section.settings.section_width | default: 'page-width'
-%}

{%- style -%}
  #alphanix-fit-tiles-{{ section.id }} {
    --fit-bg: {% if section.settings.background_color != blank %}{{ section.settings.background_color }}{% else %}#ffffff{% endif %};
    --fit-text: {% if section.settings.text_color != blank %}{{ section.settings.text_color }}{% else %}#ffffff{% endif %};
    --fit-heading: {% if section.settings.heading_color != blank %}{{ section.settings.heading_color }}{% else %}#000000{% endif %};
    background-color: var(--fit-bg);
  }
{%- endstyle -%}

<section
  id="alphanix-fit-tiles-{{ section.id }}"
  class="alphanix-fit-tiles section section--{{ section_width }} spacing-style page-width-normal"
  data-fit-tiles
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="alphanix-fit-tiles__inner">
    {%- if section.settings.heading != blank -%}
      <header class="alphanix-fit-tiles__header" data-fit-reveal>
        <h2 class="alphanix-fit-tiles__heading">{{ section.settings.heading | escape }}</h2>
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="alphanix-fit-tiles__grid" data-fit-reveal style="--fit-cols: {{ section.blocks.size }}">
        {%- for block in section.blocks -%}
          {%- liquid
            assign tile_collection = block.settings.collection
            assign tile_title = block.settings.title
            if tile_title == blank and tile_collection != blank
              assign tile_title = tile_collection.title
            endif
            assign tile_image = block.settings.image
            if tile_image == blank and tile_collection != blank and tile_collection.image != blank
              assign tile_image = tile_collection.image
            endif
            assign tile_url = block.settings.link
            if tile_url == blank and tile_collection != blank
              assign tile_url = tile_collection.url
            endif
          -%}
          {%- if tile_url != blank -%}
            <a
              href="{{ tile_url }}"
              class="alphanix-fit-tiles__tile"
              style="--stagger: {{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
          {%- else -%}
            <div
              class="alphanix-fit-tiles__tile alphanix-fit-tiles__tile--static"
              style="--stagger: {{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
          {%- endif -%}

            <div class="alphanix-fit-tiles__media">
              {%- if tile_image != blank -%}
                {{
                  tile_image
                  | image_url: width: 1600
                  | image_tag:
                    class: 'alphanix-fit-tiles__image',
                    loading: 'lazy',
                    widths: '400, 600, 800, 1000, 1200, 1600',
                    sizes: '(min-width: 750px) 33vw, 90vw',
                    alt: tile_image.alt | default: tile_title
                }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'alphanix-fit-tiles__image placeholder' }}
              {%- endif -%}
              <div class="alphanix-fit-tiles__scrim" aria-hidden="true"></div>
            </div>

            <div class="alphanix-fit-tiles__meta">
              {%- if tile_title != blank -%}
                <span class="alphanix-fit-tiles__title">{{ tile_title | escape }}</span>
              {%- endif -%}
              <span class="alphanix-fit-tiles__arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/>
                  <path d="M13 6l6 6-6 6"/>
                </svg>
              </span>
            </div>

          {%- if tile_url != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('alphanix-fit-tiles-{{ section.id }}');
    if (!root) return;

    function reveal() {
      root.classList.add('is-visible');
    }

    function init() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        reveal();
        return;
      }
      if (!('IntersectionObserver' in window)) {
        reveal();
        return;
      }
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            reveal();
            observer.disconnect();
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
      );
      observer.observe(root);
    }

    init();

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        root = document.getElementById('alphanix-fit-tiles-{{ section.id }}');
        if (root) init();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Alphanix Fit Tiles",
  "tag": "section",
  "class": "alphanix-fit-tiles-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by fit"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tile text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Fit tile",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Regular"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Optional. Falls back to the collection image."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "Optional. Falls back to the collection URL."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Alphanix Fit Tiles",
      "blocks": [
        { "type": "tile", "settings": { "title": "Regular" } },
        { "type": "tile", "settings": { "title": "Oversized" } },
        { "type": "tile", "settings": { "title": "Heavyweight" } }
      ]
    }
  ]
}
{% endschema %}
