{% comment %}
  Alphanix Lookbook — Staggered parallax image grid
{% endcomment %}

{%- style -%}
  #alphanix-lookbook-{{ section.id }} {
    --bg-color: {{ section.settings.background_color }};
    --text-color: {{ section.settings.text_color }};
    --border-color: {{ section.settings.border_color }};
    
    background-color: var(--bg-color);
    color: var(--text-color);
    border-top: 1px solid var(--border-color);
  }
{%- endstyle -%}

<alphanix-lookbook-component class="alphanix-lookbook spacing-style" id="alphanix-lookbook-{{ section.id }}" style="{% render 'spacing-style' %}">
  <div class="alphanix-lookbook__bg-text" id="alphanix-lookbook-bg-{{ section.id }}">
    {{ section.settings.background_text }}
  </div>

  <div class="alphanix-container page-width">
    <div class="alphanix-lookbook__header">
      <div>
        <div class="alphanix-eyebrow">— {{ section.settings.eyebrow }}</div>
        <h2 class="alphanix-lookbook__heading">{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="alphanix-lookbook__grid">
      <div class="alphanix-lookbook__large" id="alphanix-lookbook-img1-{{ section.id }}">
        {%- if section.settings.image_1 != blank -%}
          <img src="{{ section.settings.image_1 | image_url: width: 1800 }}" alt="{{ section.settings.image_1.alt | escape | default: 'Lookbook' }}" class="alphanix-lookbook__image" loading="lazy" width="900" height="1125">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'alphanix-lookbook__image placeholder' }}
        {%- endif -%}
      </div>

      <div class="alphanix-lookbook__stack">
        <div class="alphanix-lookbook__wide" id="alphanix-lookbook-img2-{{ section.id }}">
          {%- if section.settings.image_2 != blank -%}
            <img src="{{ section.settings.image_2 | image_url: width: 1400 }}" alt="{{ section.settings.image_2.alt | escape | default: 'Lookbook' }}" class="alphanix-lookbook__image" loading="lazy" width="700" height="525">
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'alphanix-lookbook__image placeholder' }}
          {%- endif -%}
        </div>
        <div class="alphanix-lookbook__square" id="alphanix-lookbook-img3-{{ section.id }}">
          {%- if section.settings.image_3 != blank -%}
            <img src="{{ section.settings.image_3 | image_url: width: 1400 }}" alt="{{ section.settings.image_3.alt | escape | default: 'Lookbook' }}" class="alphanix-lookbook__image" loading="lazy" width="700" height="700">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'alphanix-lookbook__image placeholder' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</alphanix-lookbook-component>

<script type="module">
  import { Component } from '@theme/component';

  if (!customElements.get('alphanix-lookbook-component')) {
    customElements.define('alphanix-lookbook-component', class AlphanixLookbookComponent extends Component {
      connectedCallback() {
        super.connectedCallback();
        this.bg = this.querySelector('.alphanix-lookbook__bg-text');
        this.images = Array.from(this.querySelectorAll('.alphanix-lookbook__large, .alphanix-lookbook__wide, .alphanix-lookbook__square'));
        this.ticking = false;
        this.isVisible = false;

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            this.isVisible = entry.isIntersecting;
            if (this.isVisible) {
              window.addEventListener('scroll', this.onScroll, { passive: true });
              this.updateParallax();
            } else {
              window.removeEventListener('scroll', this.onScroll);
            }
          });
        }, { threshold: 0, rootMargin: '100px' });

        this.observer.observe(this);
      }

      disconnectedCallback() {
        super.disconnectedCallback();
        this.observer.disconnect();
        window.removeEventListener('scroll', this.onScroll);
      }

      onScroll = () => {
        if (!this.ticking) {
          requestAnimationFrame(() => this.updateParallax());
          this.ticking = true;
        }
      }

      updateParallax() {
        this.ticking = false;
        if (!this.isVisible) return;
        
        const rect = this.getBoundingClientRect();
        const vH = window.innerHeight;
        
        // Progress goes from 0 (just entering bottom) to 1 (just leaving top)
        const p = Math.min(Math.max((vH - rect.top) / (vH + rect.height), 0), 1);
        
        if (this.bg) {
          this.bg.style.transform = `translateX(${-30 + p * 40}%)`;
        }
        
        this.images.forEach((el, idx) => {
          if (!el) return;
          const offsets = [[10, -20], [-15, 30], [5, -10]];
          const y = offsets[idx][0] + p * offsets[idx][1];
          const img = el.querySelector('.alphanix-lookbook__image');
          if (img) img.style.transform = `translateY(${y}%) scale(1.1)`; // scale up slightly so edges don't show when translating
        });
      }
    });
  }
</script>

{% stylesheet %}
  .alphanix-lookbook {
    position: relative;
    overflow: hidden;
    display: block;
  }

  /* Scrolling background text */
  .alphanix-lookbook__bg-text {
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    opacity: 0.06;
    line-height: 1;
    margin-bottom: 4rem;
    pointer-events: none;
    font-size: clamp(8rem, 22vw, 22rem);
    font-weight: 700;
    will-change: transform;
  }

  .alphanix-lookbook__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  .alphanix-eyebrow {
    margin-bottom: 1rem;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .alphanix-lookbook__heading {
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.9;
    font-size: clamp(2.5rem, 6vw, 6rem);
    margin: 0;
    font-weight: 700;
  }

  /* Grid layout */
  .alphanix-lookbook__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media screen and (min-width: 750px) {
    .alphanix-lookbook__grid {
      grid-template-columns: 7fr 5fr;
      gap: 1.5rem;
    }
  }

  .alphanix-lookbook__large {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .alphanix-lookbook__stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media screen and (min-width: 750px) {
    .alphanix-lookbook__stack {
      gap: 1.5rem;
    }
  }

  .alphanix-lookbook__wide {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .alphanix-lookbook__square {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .alphanix-lookbook__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    will-change: transform;
    transform: scale(1.1); /* Ensure enough bleed for parallax */
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Alphanix Lookbook",
  "tag": "section",
  "class": "alphanix-lookbook-section",
  "settings": [
    {"type":"header","content":"Content"},
    {"type":"text","id":"eyebrow","label":"Eyebrow label","default":"Lookbook"},
    {"type":"inline_richtext","id":"heading","label":"Heading","default":"On the edge."},
    {"type":"text","id":"background_text","label":"Background scrolling text","default":"ALPHANIX — ALPHANIX"},
    {"type":"header","content":"Images"},
    {"type":"image_picker","id":"image_1","label":"Large image (left)"},
    {"type":"image_picker","id":"image_2","label":"Top right image"},
    {"type":"image_picker","id":"image_3","label":"Bottom right image"},
    {"type":"header","content":"Colors"},
    {"type":"color","id":"background_color","label":"Background color","default":"#0a0a0a"},
    {"type":"color","id":"text_color","label":"Text color","default":"#ffffff"},
    {"type":"color","id":"border_color","label":"Top border color","default":"rgba(255, 255, 255, 0.1)"},
    {"type":"header","content":"t:content.padding"},
    {"type":"range","id":"padding-block-start","min":0,"max":200,"step":4,"unit":"px","label":"t:settings.top","default":100},
    {"type":"range","id":"padding-block-end","min":0,"max":200,"step":4,"unit":"px","label":"t:settings.bottom","default":100}
  ],
  "presets": [{"name":"Alphanix Lookbook"}]
}
{% endschema %}
